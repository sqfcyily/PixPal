{
  "name": "pixpal",
  "version": "0.1.0",
  "description": "An ultra-lightweight, pixel-art visualized personal AI assistant",
  "main": "src/main.tsx",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun run --watch src/main.tsx",
    "build": "bun build src/main.tsx --compile --outfile pixpal"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^14.1.2",
    "react": "^18.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "typescript": "^5.4.5"
  }
}
