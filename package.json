{
  "name": "liteagent",
  "version": "0.1.0",
  "description": "A lightweight, general-purpose AI agent harness",
  "main": "src/main.tsx",
  "type": "module",
  "bin": {
    "liteagent": "src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun run --watch src/main.tsx --dev",
    "build": "bun build src/main.tsx --compile --outfile liteagent",
    "global:link": "bun link",
    "global:unlink": "bun unlink"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^14.1.2",
    "react": "^18.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "bun-types": "^1.3.11",
    "typescript": "^5.4.5"
  }
}
